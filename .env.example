# Database
DB_DSN=postgresql://hgw_user:hgw_password@timescaledb:5432/hgw_monitoring
POSTGRES_USER=hgw_user
POSTGRES_PASSWORD=hgw_password
POSTGRES_DB=hgw_monitoring

# HGW metric source
HGW_HOST=192.168.1.1
HGW_USER=root
HGW_PASSWORD=change_me
HGW_PORT=23
COLLECTION_INTERVAL=5
TELNET_COMMAND_DELAY=0.4
PING_COMMAND_DELAY=1.2

# Continuous prediction
PREDICTION_INTERVAL_SECONDS=300
PREDICTION_LOOKBACK_HOURS=25
PREDICTION_FALLBACK_ROWS=20000
MIN_ROWS_FOR_PREDICTION=60
MODEL_VERSION=continuous_5min_weekly_retrain

# Weekly retraining without external orchestrator
RETRAIN_ENABLED=true
RETRAIN_INTERVAL_DAYS=7
RETRAIN_RUN_ON_START=false
RETRAIN_COMMAND=python train_multi_horizon.py
RETRAIN_STATE_FILE=/app/data/retrain_state.json

# Optional alerts
ALERT_EMAIL_TO=
ALERT_COOLDOWN_MINUTES=60
ALERT_STATE_FILE=/app/data/alert_state.json

# Optional SMTP email channel
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional Grafana email settings
GF_SMTP_ENABLED=false
GF_SMTP_HOST=
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=
GF_SMTP_SKIP_VERIFY=true
