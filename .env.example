# ============================================================
#  HGW Predictive System — Configuration
#  Copier ce fichier en .env et remplir les valeurs réelles
# ============================================================

# --- Connexion HGW (Telnet) ---
HGW_HOST=192.168.1.1
HGW_PASSWORD=your_hgw_password

# --- Base de données TimescaleDB ---
POSTGRES_USER=hgw_user
POSTGRES_PASSWORD=hgw_password
POSTGRES_DB=hgw_monitoring
DB_DSN=postgresql://hgw_user:hgw_password@timescaledb:5432/hgw_monitoring

# --- Daemon de prédiction ---
PREDICTION_INTERVAL_SECONDS=300
PREDICTION_LOOKBACK_HOURS=24
MIN_ROWS_FOR_PREDICTION=60

# --- Réentraînement automatique ---
RETRAIN_ENABLED=true
RETRAIN_INTERVAL_DAYS=7
RETRAIN_RUN_ON_START=false

# --- Alertes email (Gmail : utiliser un App Password 16 chars) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
ALERT_EMAIL_TO=recipient@gmail.com
ALERT_COOLDOWN_MINUTES=60

# --- Grafana ---
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.gmail.com
GF_SMTP_USER=your_email@gmail.com
GF_SMTP_PASSWORD=your_app_password
GF_SMTP_FROM_ADDRESS=your_email@gmail.com
GF_SMTP_SKIP_VERIFY=true
