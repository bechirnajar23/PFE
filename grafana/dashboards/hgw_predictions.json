      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT * FROM predictions_log WHERE timestamp = (SELECT MAX(timestamp) FROM predictions_log)) SELECT COALESCE(MAX(decision_level) FILTER (WHERE decision_level IS NOT NULL AND decision_level <> ''), CASE WHEN BOOL_OR(alert) THEN 'PREDICTED_INCIDENT' WHEN COUNT(*) > 0 THEN 'STABLE' ELSE 'AUCUNE DONNEE' END) AS value FROM latest",
          "refId": "A"
        }
      ],
      "title": "Decision globale",
      "type": "stat"
