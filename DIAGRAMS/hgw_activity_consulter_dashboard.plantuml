@startuml
title Activite - UC Consulter dashboard

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 10
skinparam shadowing false
skinparam Activity {
  BackgroundColor #EAF2FF
  BorderColor #24527A
  BorderThickness 1.2
  FontColor #111827
}
skinparam Diamond {
  BackgroundColor #FFF7ED
  BorderColor #C2410C
  FontColor #111827
}
skinparam Arrow {
  Color #111827
  FontColor #111827
  FontSize 9
  Thickness 1.2
}
skinparam Swimlane {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  BorderThickness 1
  TitleBackgroundColor #F8FAFC
  TitleFontStyle bold
  TitleFontColor #0F172A
}

|Admin / Operateur ISP|
start
:Ouvrir l'interface frontend\nou Grafana;
:Choisir la vue dashboard;

|Interface Frontend / Grafana|
:Afficher la page de supervision;
:Demander les donnees au backend\nou a la datasource Grafana;

|Backend API / Datasource|
:Verifier disponibilite API et DB;

if (Backend et base disponibles ?) then (oui)
  :Construire les requetes;

  |Stockage TimescaleDB|
  :Lire derniers snapshots;
  :Lire predictions recentes;
  :Lire explications SHAP\net alertes;

  |Backend API / Datasource|
  :Agreger les donnees;
  :Retourner monitoring,\npredictions, alertes et XAI;

  |Interface Frontend / Grafana|
  :Afficher les indicateurs globaux;
  :Afficher courbes CPU,\nRAM, WAN et latence;
  :Afficher probabilites\nmulti-horizon;
  :Afficher alertes et\nexplications XAI / SHAP;

  if (Etat URGENT ou CRITICAL ?) then (oui)
    :Mettre en evidence l'alerte;
    :Afficher la cause probable\net les facteurs SHAP;

    |Admin / Operateur ISP|
    :Analyser l'incident;
    :Decider action technique\nou intervention;
  else (non)
    |Admin / Operateur ISP|
    :Suivre l'etat normal\nou sous surveillance;
  endif

  |Admin / Operateur ISP|
  :Continuer la supervision;
  stop
else (non)
  |Interface Frontend / Grafana|
  :Afficher message\nd'indisponibilite;

  |Admin / Operateur ISP|
  :Verifier logs backend,\nDB ou Grafana;
  :Relancer le service concerne;
  stop
endif

@enduml
