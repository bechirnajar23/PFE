@startuml hgw_architecture_workflow
title Architecture applicative - HGW Predictive Maintenance

left to right direction

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #1F2937
skinparam ArrowThickness 1.25
skinparam ArrowFontColor #1F2937
skinparam ArrowFontSize 10

skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #94A3B8
  FontColor #0F172A
  FontStyle bold
  BorderThickness 1.2
}
skinparam node {
  BackgroundColor #FFFFFF
  BorderColor #64748B
  FontColor #111827
}
skinparam component {
  BackgroundColor #EAF2FF
  BorderColor #24527A
  FontColor #111827
  BorderThickness 1.3
}
skinparam database {
  BackgroundColor #ECFDF5
  BorderColor #15803D
  FontColor #111827
  BorderThickness 1.3
}
skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #111827
  FontColor #111827
}

actor "Operateur ISP\n/ Admin" as Admin
actor "Utilisateur\nfinal" as User

package "Domaine externe" #FFF7ED {
  node "Home Gateway\n(HGW)\n\nMetriques:\nCPU, RAM, WAN,\nDHCP, ping, latence" as HGW #FFF7ED
}

package "Plateforme conteneurisee Docker" #F8FAFC {
  package "Couche ingestion" #EFF6FF {
    component "Collector Python\n\nReception metriques\nNormalisation\nRegles metier" as Collector
  }

  package "Couche donnees" #ECFDF5 {
    database "TimescaleDB\nPostgreSQL\n\nmonitor_snapshots\npredictions_log\nexplainer_json" as DB
  }

  package "Couche IA" #F5F3FF {
    component "Prediction Service\n\nExecution chaque 5 min\nFeature engineering\nDecision seuils" as Predict
    component "CatBoost\n15 / 30 / 60 / 360 min" as CatBoost
    component "LSTM TensorFlow\nHorizon 3 jours" as LSTM
    component "XAI Engine\nSHAP CatBoost\n+ regles metier" as XAI
    component "Retraining\nTous les 7 jours" as Retrain
  }

  package "Couche API et presentation" #EEF2FF {
    component "Backend API\nFastAPI\n\n/summary\n/predictions\n/xai/latest" as API
    component "Frontend React\nMonitoring\nPredictions\nAlertes\nSHAP" as Front
    component "Grafana\nDashboards techniques" as Grafana
  }

  package "Couche notification" #FFF7ED {
    component "SMS Service\nTwilio\n+ SMTP Email" as SMS
  }
}

HGW -[#2563EB,dashed]-> Collector : "1. Envoi metriques\nport dedie"
Collector -[#2563EB]-> DB : "2. Stockage snapshots\n+ explication metier"

DB -[#16A34A]-> Predict : "3. Donnees recentes\n+ historique"
Predict -[#16A34A]-> CatBoost : "4a. Prediction court terme"
Predict -[#16A34A]-> LSTM : "4b. Prediction 3 jours"
CatBoost -[#9333EA]-> XAI : "5. Valeurs SHAP"
Predict -[#16A34A]-> DB : "6. Enregistrer probabilites\nseuils et decisions"
XAI -[#9333EA]-> DB : "7. Enregistrer explainer_json"

Predict -[#EA580C]-> SMS : "8. Alerte si\nURGENT/CRITICAL"
SMS -[#EA580C]-> User : "9. SMS / Email\navec cause + XAI"

DB -[#0F766E]-> API : "10. Requetes API"
API -[#0F766E]-> Front : "11. Donnees UI"
DB -[#F59E0B]-> Grafana : "12. Requetes SQL"
Admin -[#0F766E]-> Front : "13. Supervision"
Admin -[#F59E0B]-> Grafana : "14. Analyse technique"

DB -[#475569]-> Retrain : "15. Historique 7 jours"
Retrain -[#475569]-> CatBoost : "16. Mise a jour modeles"

legend right
  == Legende ==
  <color:#2563EB>Bleu</color> : ingestion
  <color:#16A34A>Vert</color> : prediction
  <color:#9333EA>Violet</color> : explicabilite SHAP
  <color:#EA580C>Orange</color> : notification
  <color:#0F766E>Turquoise</color> : API / frontend
  <color:#F59E0B>Ambre</color> : Grafana
  <color:#475569>Gris</color> : reentrainement
endlegend

footer Architecture par couches: ingestion -> donnees -> IA -> XAI -> notification -> presentation

@enduml
