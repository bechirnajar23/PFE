@startuml
title Activite globale - HGW Predictive Maintenance

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 10
skinparam shadowing false
skinparam Activity {
  BackgroundColor #EAF2FF
  BorderColor #24527A
  BorderThickness 1.2
  FontColor #111827
}
skinparam Diamond {
  BackgroundColor #FFF7ED
  BorderColor #C2410C
  FontColor #111827
}
skinparam Arrow {
  Color #111827
  FontColor #111827
  FontSize 9
  Thickness 1.2
}
skinparam Swimlane {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  BorderThickness 1
  TitleBackgroundColor #F8FAFC
  TitleFontStyle bold
  TitleFontColor #0F172A
}

|Humain|
start
:Lancer la stack Docker;
:Consulter interface\nfrontend ou Grafana;

|Systemes / Interfaces|
:Activer service de collecte;
:Ouvrir port d'ecoute metriques;

while (Monitoring actif ?) is (oui)
  |Systemes / Interfaces|
  :Recevoir metriques HGW;
  :Normaliser le snapshot;
  :Evaluer etat local\npar regles metier;
  :Generer explication metier;

  if (Snapshot valide ?) then (oui)
    |Stockage|
    :Inserer monitor_snapshots;
  else (non)
    |Systemes / Interfaces|
    :Completer avec fallback\nou valeurs connues;
    |Stockage|
    :Inserer snapshot partiel;
  endif

  |Systemes / Interfaces|
  :Attendre cycle prediction\n5 minutes;
  :Lire mesures recentes;

  if (Historique suffisant ?) then (oui)
    :Construire features ML/DL;
    :Executer modeles CatBoost;
    :Executer modele LSTM;
    :Comparer aux seuils;
    :Calculer SHAP CatBoost;

    |Stockage|
    :Inserer predictions_log\n+ explainer_json;

    |Systemes / Interfaces|
    if (Etat courant\nURGENT ou CRITICAL ?) then (oui)
      :Preparer notification\navec cause + XAI;
      :Envoyer SMS ou Email;
      |Humain|
      :Utilisateur final\nrecoit l'alerte;
    else (non)
      |Humain|
      :Operateur consulte\nsurveillance sans notification;
    endif
  else (non)
    |Stockage|
    :Historiser diagnostic\nhistorique insuffisant;
    |Systemes / Interfaces|
    :Attendre plus de donnees;
  endif

  |Systemes / Interfaces|
  if (7 jours ecoules ?) then (oui)
    |Stockage|
    :Fournir historique\nentrainement;
    |Systemes / Interfaces|
    :Reentrainer modeles;
    :Recharger artefacts IA;
  else (non)
    :Conserver modeles actifs;
  endif

  |Stockage|
  :Exposer donnees\nAPI / Grafana;

  |Humain|
  :Analyser mesures,\npredictions et SHAP;
endwhile (non)

|Humain|
:Arreter le monitoring;
stop

@enduml
